@model DernekYonetim.Models.Etkinlik
@{
    ViewData["Title"] = "Katılımcılar";
    var onaylananlar = Model.Kayitlar
        .Where(k => k.Durum == DernekYonetim.Models.EtkinlikKayitDurumu.Onaylandi)
        .ToList();
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4><i class="bi bi-people"></i> Katılımcılar — @Model.Baslik</h4>
        <a asp-action="Detay" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Geri
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Ad Soyad</th>
                        <th>E-posta</th>
                        <th>Kayıt Tarihi</th>
                        <th>Katıldı mı?</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < onaylananlar.Count; i++)
                    {
                        var k = onaylananlar[i];
                        <tr>
                            <td>@(i + 1)</td>
                            <td>@k.Uye?.TamAd</td>
                            <td>@k.Uye?.Email</td>
                            <td>@k.KayitTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                @if (k.KatildiMi)
                                {
                                    <span class="badge bg-success">Katıldı</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Bekleniyor</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!onaylananlar.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                Henüz kayıt yok.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>