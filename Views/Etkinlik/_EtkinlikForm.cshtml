@model DernekYonetim.ViewModels.EtkinlikViewModel

<form asp-action="@(Model.Id == 0 ? "Olustur" : "Duzenle")" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

    <div class="mb-3">
        <label asp-for="Baslik" class="form-label">Başlık *</label>
        <input asp-for="Baslik" class="form-control" />
        <span asp-validation-for="Baslik" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Aciklama" class="form-label">Açıklama</label>
        <textarea asp-for="Aciklama" class="form-control" rows="3"></textarea>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Kategori" class="form-label">Kategori *</label>
            <select asp-for="Kategori" class="form-select">
                <option value="Seminer"  selected="@(Model.Kategori == DernekYonetim.Models.EtkinlikKategori.Seminer)">Seminer</option>
                <option value="Toplanti" selected="@(Model.Kategori == DernekYonetim.Models.EtkinlikKategori.Toplanti)">Toplantı</option>
                <option value="Sosyal"   selected="@(Model.Kategori == DernekYonetim.Models.EtkinlikKategori.Sosyal)">Sosyal</option>
                <option value="Spor"     selected="@(Model.Kategori == DernekYonetim.Models.EtkinlikKategori.Spor)">Spor</option>
                <option value="Egitim"   selected="@(Model.Kategori == DernekYonetim.Models.EtkinlikKategori.Egitim)">Eğitim</option>
            </select>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Durum" class="form-label">Durum</label>
            <select asp-for="Durum" class="form-select">
                <option value="Taslak"     selected="@(Model.Durum == DernekYonetim.Models.EtkinlikDurumu.Taslak)">Taslak</option>
                <option value="Yayinda"    selected="@(Model.Durum == DernekYonetim.Models.EtkinlikDurumu.Yayinda)">Yayında</option>
                <option value="Iptal"      selected="@(Model.Durum == DernekYonetim.Models.EtkinlikDurumu.Iptal)">İptal</option>
                <option value="Tamamlandi" selected="@(Model.Durum == DernekYonetim.Models.EtkinlikDurumu.Tamamlandi)">Tamamlandı</option>
            </select>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Yer" class="form-label">Yer</label>
        <input asp-for="Yer" class="form-control" placeholder="Etkinlik yeri" />
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="BaslangicTarihi" class="form-label">Başlangıç *</label>
            <input asp-for="BaslangicTarihi" type="datetime-local" class="form-control"
                   value="@Model.BaslangicTarihi.ToString("yyyy-MM-ddTHH:mm")" />
            <span asp-validation-for="BaslangicTarihi" class="text-danger small"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="BitisTarihi" class="form-label">Bitiş *</label>
            <input asp-for="BitisTarihi" type="datetime-local" class="form-control"
                   value="@Model.BitisTarihi.ToString("yyyy-MM-ddTHH:mm")" />
            <span asp-validation-for="BitisTarihi" class="text-danger small"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Kontenjan" class="form-label">Kontenjan (boş = sınırsız)</label>
        <input asp-for="Kontenjan" type="number" class="form-control" min="1" />
    </div>

    <div class="mb-3 form-check">
        <input asp-for="UcretsizMi" class="form-check-input" id="ucretsizCheck"
               onchange="toggleUcret(this)" />
        <label asp-for="UcretsizMi" class="form-check-label">Ücretsiz</label>
    </div>

    <div class="mb-3" id="ucretAlani" style="display:@(Model.UcretsizMi ? "none" : "block")">
        <label asp-for="Ucret" class="form-label">Ücret (₺)</label>
        <input asp-for="Ucret" type="number" step="0.01" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary w-100">
        <i class="bi bi-save"></i> Kaydet
    </button>
</form>

@section Scripts {
    <script>
        function toggleUcret(cb) {
            document.getElementById('ucretAlani').style.display = cb.checked ? 'none' : 'block';
        }
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}