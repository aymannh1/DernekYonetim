@model List<DernekYonetim.Models.Duyuru>
@{
    ViewData["Title"] = "Duyuru Yönetimi";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4><i class="bi bi-megaphone"></i> Duyuru Yönetimi</h4>
        <a asp-action="Olustur" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle"></i> Yeni Duyuru
        </a>
    </div>

    @if (TempData["Basari"] != null)
    {
        <div class="alert alert-success">@TempData["Basari"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Başlık</th>
                        <th>Hedef</th>
                        <th>Kamuoyuna</th>
                        <th>Tarih</th>
                        <th>Durum</th>
                        <th>İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model)
                    {
                        <tr>
                            <td>@d.Baslik</td>
                            <td><span class="badge bg-secondary">@d.Hedef</span></td>
                            <td>
                                @if (d.KamuoyunaAcik)
                                {
                                    <span class="badge bg-info">Açık</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark">Kapalı</span>
                                }
                            </td>
                            <td>@d.OlusturmaTarihi.ToString("dd.MM.yyyy")</td>
                            <td>
                                @if (d.Aktif)
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Pasif</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Duzenle" asp-route-id="@d.Id"
                                   class="btn btn-outline-secondary btn-sm">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Sil" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@d.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm"
                                            onclick="return confirm('Silmek istediğinizden emin misiniz?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                Henüz duyuru bulunmuyor.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>