@model List<DernekYonetim.Models.Duyuru>
@{
    ViewData["Title"] = "Duyurular";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4><i class="bi bi-megaphone"></i> Duyurular</h4>
        @if (User.IsInRole("Admin") || User.IsInRole("Yonetim"))
        {
            <a asp-action="Yonetim" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-gear"></i> Duyuru Yönetimi
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-megaphone" style="font-size:3rem"></i>
            <p class="mt-2">Henüz duyuru bulunmuyor.</p>
        </div>
    }
    else
    {
        @foreach (var d in Model)
        {
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <h5 class="card-title mb-1">@d.Baslik</h5>
                        <div class="d-flex gap-1">
                            @if (d.KamuoyunaAcik)
                            {
                                <span class="badge bg-info">Kamuoyuna Açık</span>
                            }
                            <span class="badge bg-secondary">@d.Hedef</span>
                        </div>
                    </div>
                    <p class="text-muted small mb-2">
                        <i class="bi bi-clock"></i>
                        @d.OlusturmaTarihi.ToString("dd.MM.yyyy HH:mm")
                    </p>
                    @if (!string.IsNullOrEmpty(d.Ozet))
                    {
                        <p class="card-text">@d.Ozet</p>
                    }
                    <a asp-action="Detay" asp-route-id="@d.Id"
                       class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-arrow-right"></i> Devamını Oku
                    </a>
                </div>
            </div>
        }
    }
</div>