@model DernekYonetim.Models.Proje
@{
    ViewData["Title"] = Model.Baslik;
    var fotograflar = Model.Belgeler.Where(b => b.Tur == DernekYonetim.Models.ProjeBelgeTuru.Fotograf).ToList();
    var belgeler = Model.Belgeler.Where(b => b.Tur == DernekYonetim.Models.ProjeBelgeTuru.Belge).ToList();
    var videolar = Model.Belgeler.Where(b => b.Tur == DernekYonetim.Models.ProjeBelgeTuru.Video).ToList();
    var sonGuncelleme = Model.Guncellemeler.OrderByDescending(g => g.Tarih).FirstOrDefault();
    var ilerleme = sonGuncelleme != null ? (int)sonGuncelleme.IlerlemeYuzdesi : 0;
    var kultur = new System.Globalization.CultureInfo("tr-TR");
    bool yetkili = User.IsInRole("Admin") || User.IsInRole("Yonetim");
}

<div class="container">

    @if (TempData["Basari"] != null)
    {
        <div class="alert alert-success">@TempData["Basari"]</div>
    }
    @if (TempData["Hata"] != null)
    {
        <div class="alert alert-danger">@TempData["Hata"]</div>
    }

    <!-- BAŞLIK -->
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h4 class="mb-1">@Model.Baslik</h4>
            <p class="text-muted mb-0">
                <i class="bi bi-geo-alt"></i> @Model.Ulke
                @if (!string.IsNullOrEmpty(Model.Sehir))
                {
                    <span>/ @Model.Sehir</span>
                }
            </p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Geri
            </a>
            @if (yetkili)
            {
                <a asp-action="Duzenle" asp-route-id="@Model.Id"
                   class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-pencil"></i> Düzenle
                </a>
            }
        </div>
    </div>

    <div class="row g-4">

        <!-- SOL KOLON -->
        <div class="col-md-8">

            <!-- Kapak fotoğrafı -->
            @if (!string.IsNullOrEmpty(Model.KapakFotoUrl))
            {
                <img src="@Model.KapakFotoUrl" class="img-fluid rounded mb-4 w-100"
                     style="max-height:400px;object-fit:cover" alt="@Model.Baslik" />
            }

            <!-- Açıklama -->
            @if (!string.IsNullOrEmpty(Model.Aciklama))
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <h6 class="fw-bold mb-2">Proje Hakkında</h6>
                        <p class="mb-0">@Model.Aciklama</p>
                    </div>
                </div>
            }

            <!-- ── FOTOĞRAFLAR ── -->
            <div class="card shadow-sm mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong><i class="bi bi-images"></i> Fotoğraflar (@fotograflar.Count)</strong>
                    @if (yetkili)
                    {
                        <button class="btn btn-outline-primary btn-sm" data-bs-toggle="modal"
                                data-bs-target="#belgeModal" data-tur="Fotograf">
                            <i class="bi bi-plus"></i> Fotoğraf Ekle
                        </button>
                    }
                </div>
                <div class="card-body">
                    @if (!fotograflar.Any())
                    {
                        <p class="text-muted small mb-0">Henüz fotoğraf yüklenmedi.</p>
                    }
                    else
                    {
                        <div class="row g-2">
                            @foreach (var f in fotograflar)
                            {
                                <div class="col-md-3 col-4">
                                    <div class="position-relative">
                                        <a href="@f.DosyaYoluVeyaLink" target="_blank">
                                            <img src="@f.DosyaYoluVeyaLink"
                                                 class="img-fluid rounded"
                                                 style="height:100px;width:100%;object-fit:cover"
                                                 alt="@f.Baslik" title="@f.Baslik" />
                                        </a>
                                        @if (yetkili)
                                        {
                                            <form asp-action="BelgeSil" method="post"
                                                  class="position-absolute top-0 end-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@f.Id" />
                                                <input type="hidden" name="projeId" value="@Model.Id" />
                                                <button type="submit"
                                                        class="btn btn-danger btn-sm py-0 px-1"
                                                        onclick="return confirm('Sil?')"
                                                        style="font-size:0.7rem">
                                                    <i class="bi bi-x"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- ── VİDEOLAR ── -->
            <div class="card shadow-sm mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong><i class="bi bi-play-circle"></i> Videolar (@videolar.Count)</strong>
                    @if (yetkili)
                    {
                        <button class="btn btn-outline-danger btn-sm" data-bs-toggle="modal"
                                data-bs-target="#belgeModal" data-tur="Video">
                            <i class="bi bi-plus"></i> Video Ekle
                        </button>
                    }
                </div>
                <div class="card-body">
                    @if (!videolar.Any())
                    {
                        <p class="text-muted small mb-0">Henüz video eklenmedi.</p>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var v in videolar)
                            {
                                <div class="col-md-6">
                                    <div class="card border">
                                        <div class="card-body p-2">
                                            <p class="fw-bold small mb-1">@v.Baslik</p>
                                            @if (!string.IsNullOrEmpty(v.Aciklama))
                                            {
                                                <p class="text-muted small mb-1">@v.Aciklama</p>
                                            }
                                            <a href="@v.DosyaYoluVeyaLink" target="_blank"
                                               class="btn btn-danger btn-sm w-100">
                                                <i class="bi bi-youtube"></i> Videoyu İzle
                                            </a>
                                        </div>
                                        @if (yetkili)
                                        {
                                            <div class="card-footer p-1">
                                                <form asp-action="BelgeSil" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@v.Id" />
                                                    <input type="hidden" name="projeId" value="@Model.Id" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm w-100"
                                                            onclick="return confirm('Sil?')">
                                                        <i class="bi bi-trash"></i> Sil
                                                    </button>
                                                </form>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- ── BELGELER ── -->
            <div class="card shadow-sm mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong><i class="bi bi-file-earmark"></i> Belgeler (@belgeler.Count)</strong>
                    @if (yetkili)
                    {
                        <button class="btn btn-outline-success btn-sm" data-bs-toggle="modal"
                                data-bs-target="#belgeModal" data-tur="Belge">
                            <i class="bi bi-plus"></i> Belge Ekle
                        </button>
                    }
                </div>
                <div class="card-body p-0">
                    @if (!belgeler.Any())
                    {
                        <p class="text-muted small p-3 mb-0">Henüz belge yüklenmedi.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var b in belgeler)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <i class="bi bi-file-earmark-pdf text-danger me-2"></i>
                                        <span class="fw-500">@b.Baslik</span>
                                        @if (!string.IsNullOrEmpty(b.Aciklama))
                                        {
                                            <small class="text-muted ms-2">— @b.Aciklama</small>
                                        }
                                    </div>
                                    <div class="d-flex gap-1">
                                        <a href="@b.DosyaYoluVeyaLink" target="_blank"
                                           class="btn btn-outline-primary btn-sm">
                                            <i class="bi bi-download"></i>
                                        </a>
                                        @if (yetkili)
                                        {
                                            <form asp-action="BelgeSil" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@b.Id" />
                                                <input type="hidden" name="projeId" value="@Model.Id" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm"
                                                        onclick="return confirm('Sil?')">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

            <!-- ── GÜNCELLEMELER ── -->
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong><i class="bi bi-clock-history"></i> Proje Güncellemeleri</strong>
                    @if (yetkili)
                    {
                        <button class="btn btn-outline-primary btn-sm" data-bs-toggle="modal"
                                data-bs-target="#guncellemeModal">
                            <i class="bi bi-plus"></i> Güncelleme Ekle
                        </button>
                    }
                </div>
                <div class="card-body">
                    @if (!Model.Guncellemeler.Any())
                    {
                        <p class="text-muted small mb-0">Henüz güncelleme yok.</p>
                    }
                    else
                    {
                        @foreach (var g in Model.Guncellemeler.OrderByDescending(x => x.Tarih))
                        {
                            <div class="border-start border-primary border-3 ps-3 mb-3">
                                <div class="d-flex justify-content-between">
                                    <strong>@g.Baslik</strong>
                                    <small class="text-muted">@g.Tarih.ToString("dd.MM.yyyy")</small>
                                </div>
                                <p class="mb-1 small">@g.Icerik</p>
                                <span class="badge bg-success">%@((int)g.IlerlemeYuzdesi) tamamlandı</span>
                            </div>
                        }
                    }
                </div>
            </div>

        </div>

        <!-- SAĞ KOLON — BİLGİLER -->
        <div class="col-md-4">

            <!-- Proje Bilgileri -->
            <div class="card shadow-sm mb-3">
                <div class="card-header"><strong>Proje Bilgileri</strong></div>
                <div class="card-body">
                    <dl class="row mb-0 small">
                        <dt class="col-sm-5">Kategori</dt>
                        <dd class="col-sm-7">
                            @(Model.Kategori == DernekYonetim.Models.ProjeKategori.SuKuyusu ? "Su Kuyusu" :
                                                        Model.Kategori == DernekYonetim.Models.ProjeKategori.OkulInsaati ? "Okul İnşaatı" :
                                                        Model.Kategori == DernekYonetim.Models.ProjeKategori.CamiInsaati ? "Cami İnşaatı" :
                                                        Model.Kategori == DernekYonetim.Models.ProjeKategori.GidaYardimi ? "Gıda Yardımı" :
                                                        Model.Kategori == DernekYonetim.Models.ProjeKategori.Katarakt ? "Katarakt" :
                                                        Model.DigerKategori ?? "Diğer")
                        </dd>

                        <dt class="col-sm-5">Durum</dt>
                        <dd class="col-sm-7">
                            <span class="badge @(Model.Durum == DernekYonetim.Models.ProjeDurumu.Tamamlandi ? "bg-success" :
                                                                                    Model.Durum == DernekYonetim.Models.ProjeDurumu.Devam ? "bg-primary" :
                                                                                    Model.Durum == DernekYonetim.Models.ProjeDurumu.Planlandi ? "bg-warning text-dark" : "bg-secondary")">
                                @(Model.Durum == DernekYonetim.Models.ProjeDurumu.Tamamlandi ? "Tamamlandı" :
                                                                Model.Durum == DernekYonetim.Models.ProjeDurumu.Devam ? "Devam Ediyor" :
                                                                Model.Durum == DernekYonetim.Models.ProjeDurumu.Planlandi ? "Planlandı" : "Durduruldu")
                            </span>
                        </dd>

                        <dt class="col-sm-5">Ülke</dt>
                        <dd class="col-sm-7">@Model.Ulke</dd>

                        @if (!string.IsNullOrEmpty(Model.Sehir))
                        {
                            <dt class="col-sm-5">Şehir</dt>
                            <dd class="col-sm-7">@Model.Sehir</dd>
                        }

                        <dt class="col-sm-5">Başlangıç</dt>
                        <dd class="col-sm-7">@Model.BaslangicTarihi.ToString("dd.MM.yyyy")</dd>

                        @if (Model.BitisTarihi.HasValue)
                        {
                            <dt class="col-sm-5">Bitiş</dt>
                            <dd class="col-sm-7">@Model.BitisTarihi.Value.ToString("dd.MM.yyyy")</dd>
                        }

                        @if (Model.HedefBütce.HasValue)
                        {
                            <dt class="col-sm-5">Hedef Bütçe</dt>
                            <dd class="col-sm-7">@Model.HedefBütce.Value.ToString("C", kultur)</dd>
                        }

                        @if (Model.ToplamBagis.HasValue)
                        {
                            <dt class="col-sm-5">Toplam Bağış</dt>
                            <dd class="col-sm-7 text-success fw-bold">
                                @Model.ToplamBagis.Value.ToString("C", kultur)
                            </dd>
                        }
                    </dl>
                </div>
            </div>

            <!-- İlerleme -->
            <div class="card shadow-sm mb-3">
                <div class="card-header"><strong>İlerleme Durumu</strong></div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-1">
                        <small>Tamamlanma</small>
                        <small class="fw-bold">%@ilerleme</small>
                    </div>
                    <div class="progress" style="height:12px">
                        <div class="progress-bar bg-success" style="width:@ilerleme%"></div>
                    </div>
                </div>
            </div>

            <!-- İçerik özeti -->
            <div class="card shadow-sm">
                <div class="card-header"><strong>İçerik Özeti</strong></div>
                <div class="card-body">
                    <div class="d-flex justify-content-between py-1 border-bottom">
                        <span><i class="bi bi-image text-primary"></i> Fotoğraflar</span>
                        <strong>@fotograflar.Count</strong>
                    </div>
                    <div class="d-flex justify-content-between py-1 border-bottom">
                        <span><i class="bi bi-play-circle text-danger"></i> Videolar</span>
                        <strong>@videolar.Count</strong>
                    </div>
                    <div class="d-flex justify-content-between py-1">
                        <span><i class="bi bi-file-earmark text-success"></i> Belgeler</span>
                        <strong>@belgeler.Count</strong>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- ── BELGE YÜKLEME MODAL ── -->
@if (yetkili)
{
    <div class="modal fade" id="belgeModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="BelgeYukle" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ProjeId" value="@Model.Id" />
                    <input type="hidden" name="Tur" id="belgeModalTur" />

                    <div class="modal-header">
                        <h5 class="modal-title" id="belgeModalBaslik">İçerik Ekle</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Başlık *</label>
                            <input name="Baslik" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Açıklama</label>
                            <input name="Aciklama" class="form-control" />
                        </div>

                        <!-- Fotoğraf / Belge için -->
                        <div id="dosyaAlani" class="mb-3">
                            <label class="form-label">Dosya *</label>
                            <input name="Dosya" type="file" class="form-control"
                                   accept=".jpg,.jpeg,.png,.pdf,.doc,.docx,.xlsx" />
                        </div>

                        <!-- Video için -->
                        <div id="videoAlani" class="mb-3" style="display:none">
                            <label class="form-label">YouTube / Google Drive Linki *</label>
                            <input name="VideoLink" class="form-control"
                                   placeholder="https://youtube.com/watch?v=..." />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                        <button type="submit" class="btn btn-primary">Ekle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ── GÜNCELLEME MODAL ── -->
    <div class="modal fade" id="guncellemeModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="GuncellemeEkle" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ProjeId" value="@Model.Id" />
                    <div class="modal-header">
                        <h5 class="modal-title">Güncelleme Ekle</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Başlık *</label>
                            <input name="Baslik" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">İçerik *</label>
                            <textarea name="Icerik" class="form-control" rows="4" required></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">İlerleme Yüzdesi</label>
                            <select name="IlerlemeYuzdesi" class="form-select">
                                @foreach (var y in Enum.GetValues<DernekYonetim.Models.ProjeIlerleme>())
                                {
                                    <option value="@((int)y)">%@((int)y)</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                        <button type="submit" class="btn btn-primary">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.getElementById('belgeModal').addEventListener('show.bs.modal', function (e) {
            var tur = e.relatedTarget.dataset.tur;
            document.getElementById('belgeModalTur').value = tur;

            var baslik = tur === 'Fotograf' ? 'Fotoğraf Ekle' :
                         tur === 'Video'    ? 'Video Ekle' : 'Belge Ekle';
            document.getElementById('belgeModalBaslik').textContent = baslik;

            document.getElementById('dosyaAlani').style.display = tur === 'Video' ? 'none' : 'block';
            document.getElementById('videoAlani').style.display = tur === 'Video' ? 'block' : 'none';
        });
    </script>
}