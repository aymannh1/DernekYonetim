@model List<DernekYonetim.Models.MaliHareket>
@{
    ViewData["Title"] = "Mali İşlemler";
    var kultur = new System.Globalization.CultureInfo("tr-TR");
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4><i class="bi bi-cash-stack"></i> Mali İşlemler</h4>
        <div class="d-flex gap-2">
            <a asp-action="Rapor" class="btn btn-outline-info btn-sm">
                <i class="bi bi-bar-chart"></i> Rapor
            </a>
            <a asp-action="Ekle" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-circle"></i> Yeni Kayıt
            </a>
        </div>
    </div>

    @if (TempData["Basari"] != null)
    {
        <div class="alert alert-success">@TempData["Basari"]</div>
    }

    <!-- İSTATİSTİK -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-success shadow-sm">
                <div class="card-body">
                    <div class="small">Toplam Gelir (@ViewBag.SeciliYil)</div>
                    <div class="fs-4 fw-bold">
                        @(((decimal)ViewBag.ToplamGelir).ToString("C", kultur))
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-danger shadow-sm">
                <div class="card-body">
                    <div class="small">Toplam Gider (@ViewBag.SeciliYil)</div>
                    <div class="fs-4 fw-bold">
                        @(((decimal)ViewBag.ToplamGider).ToString("C", kultur))
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white @((decimal)ViewBag.NetBakiye >= 0 ? "bg-primary" : "bg-warning") shadow-sm">
                <div class="card-body">
                    <div class="small">Net Bakiye</div>
                    <div class="fs-4 fw-bold">
                        @(((decimal)ViewBag.NetBakiye).ToString("C", kultur))
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FİLTRE -->
    <form method="get" class="row g-2 mb-3">
        <div class="col-md-3">
            <input type="number" name="yil" value="@ViewBag.SeciliYil"
                   class="form-control" placeholder="Yıl" min="2000" max="2100" />
        </div>
        <div class="col-md-3">
            <select name="tur" class="form-select">
                <option value="">-- Tüm Türler --</option>
                <option value="Gelir" selected="@(ViewBag.SeciliTur?.ToString() == "Gelir")">Gelir</option>
                <option value="Gider" selected="@(ViewBag.SeciliTur?.ToString() == "Gider")">Gider</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Filtrele</button>
        </div>
    </form>

    <!-- TABLO -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tarih</th>
                        <th>Tür</th>
                        <th>Kategori</th>
                        <th>Açıklama</th>
                        <th>Tutar</th>
                        <th>Kaydeden</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model)
                    {
                        <tr>
                            <td>@m.IslemTarihi.ToString("dd.MM.yyyy")</td>
                            <td>
                                @if (m.Tur == DernekYonetim.Models.MaliHareketTuru.Gelir)
                                {
                                    <span class="badge bg-success">Gelir</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Gider</span>
                                }
                            </td>
                            <td>@m.Kategori</td>
                            <td>@m.Aciklama</td>
                            <td class="fw-bold @(m.Tur == DernekYonetim.Models.MaliHareketTuru.Gelir ? "text-success" : "text-danger")">
                                @m.Tutar.ToString("C", kultur)
                            </td>
                            <td>@m.KaydEden?.TamAd</td>
                            <td>
                                <form asp-action="Sil" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@m.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm"
                                            onclick="return confirm('Silmek istediğinizden emin misiniz?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                Kayıt bulunamadı.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>