@{
    ViewData["Title"] = "Mali Rapor";
    var kultur = new System.Globalization.CultureInfo("tr-TR");
    var aylikRapor = ViewBag.AylikRapor as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4><i class="bi bi-bar-chart"></i> Mali Rapor — @ViewBag.Yil</h4>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Geri
        </a>
    </div>

    <!-- ÖZET -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-success shadow-sm">
                <div class="card-body text-center">
                    <div class="small">Yıllık Toplam Gelir</div>
                    <div class="fs-3 fw-bold">
                        @((decimal)ViewBag.ToplamGelir).ToString("C", kultur)
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-danger shadow-sm">
                <div class="card-body text-center">
                    <div class="small">Yıllık Toplam Gider</div>
                    <div class="fs-3 fw-bold">
                        @((decimal)ViewBag.ToplamGider).ToString("C", kultur)
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-primary shadow-sm">
                <div class="card-body text-center">
                    <div class="small">Net Bakiye</div>
                    <div class="fs-3 fw-bold">
                        @(((decimal)ViewBag.ToplamGelir - (decimal)ViewBag.ToplamGider).ToString("C", kultur))
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- AYLIK TABLO -->
    <div class="card shadow-sm">
        <div class="card-header"><strong>Aylık Özet</strong></div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Ay</th>
                        <th class="text-success">Gelir</th>
                        <th class="text-danger">Gider</th>
                        <th>Net</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ay in aylikRapor)
                    {
                        decimal net = (decimal)ay.Gelir - (decimal)ay.Gider;
                        <tr>
                            <td><strong>@ay.AyAdi</strong></td>
                            <td class="text-success">@((decimal)ay.Gelir).ToString("C", kultur)</td>
                            <td class="text-danger">@((decimal)ay.Gider).ToString("C", kultur)</td>
                            <td class="fw-bold @(net >= 0 ? "text-primary" : "text-warning")">
                                @net.ToString("C", kultur)
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>