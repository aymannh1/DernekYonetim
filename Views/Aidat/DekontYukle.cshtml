@model DernekYonetim.ViewModels.DekontYukleViewModel
@{
    ViewData["Title"] = "Dekont Yükle";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4><i class="bi bi-upload"></i> Dekont Yükle</h4>
                <a asp-action="Aidatlarim" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left"></i> Geri
                </a>
            </div>
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="alert alert-info small mb-3">
                        <strong>Dönem:</strong> @Model.Donem &nbsp;|&nbsp;
                        <strong>Tutar:</strong> @Model.Tutar.ToString("C", new System.Globalization.CultureInfo("tr-TR"))
                    </div>

                    <form asp-action="DekontYukle" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="AidatId" />
                        <input type="hidden" asp-for="Donem" />
                        <input type="hidden" asp-for="Tutar" />

                        <div class="mb-3">
                            <label asp-for="OdemeYontemi" class="form-label">Ödeme Yöntemi *</label>
                            <select asp-for="OdemeYontemi" class="form-select"
                                    asp-items="Html.GetEnumSelectList<DernekYonetim.Models.OdemeYontemi>()">
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Dekont" class="form-label">Dekont Dosyası *</label>
                            <input asp-for="Dekont" type="file" class="form-control"
                                   accept=".pdf,.jpg,.jpeg,.png" />
                            <div class="form-text">PDF, JPG veya PNG — Max 10MB</div>
                            <span asp-validation-for="Dekont" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-upload"></i> Yükle ve Gönder
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}