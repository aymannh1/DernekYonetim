@model DernekYonetim.ViewModels.TopluAidatViewModel
@{
    ViewData["Title"] = "Toplu Aidat Oluştur";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4><i class="bi bi-plus-circle"></i> Toplu Aidat Oluştur</h4>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left"></i> Geri
                </a>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="alert alert-info small">
                        <i class="bi bi-info-circle"></i>
                        Tüm <strong>aktif üyeler</strong> için seçilen dönemde aidat kaydı oluşturulur.
                        Zaten kaydı olanlar atlanır.
                    </div>

                    <form asp-action="TopluOlustur" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                        <div class="mb-3">
                            <label asp-for="Donem" class="form-label">Dönem (YYYY-MM)</label>
                            <input asp-for="Donem" class="form-control" placeholder="2026-05" />
                            <span asp-validation-for="Donem" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Tutar" class="form-label">Aidat Tutarı (₺)</label>
                            <input asp-for="Tutar" type="number" step="0.01" class="form-control" />
                            <span asp-validation-for="Tutar" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SonOdemeTarihi" class="form-label">Son Ödeme Tarihi</label>
                            <input asp-for="SonOdemeTarihi" type="date" class="form-control"
                                   value="@Model.SonOdemeTarihi.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="SonOdemeTarihi" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-save"></i> Oluştur
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}