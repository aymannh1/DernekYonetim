@model List<DernekYonetim.Models.Bildirim>
@{
    ViewData["Title"] = "Bildirimlerim";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4><i class="bi bi-bell"></i> Bildirimlerim</h4>
        <span class="badge bg-secondary">@Model.Count bildirim</span>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-bell-slash" style="font-size:3rem"></i>
            <p class="mt-2">Henüz bildiriminiz yok.</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-2">
            @foreach (var b in Model)
            {
                <div class="card shadow-sm @(b.OkunduMu ? "" : "border-primary")">
                    <div class="card-body py-3">
                        <div class="d-flex align-items-start gap-3">
                            <div class="flex-shrink-0 mt-1">
                                @switch (b.Tur)
                                {
                                    case DernekYonetim.Models.BildirimTuru.Aidat:
                                        <i class="bi bi-cash-coin text-warning fs-5"></i>
                                        break;
                                    case DernekYonetim.Models.BildirimTuru.Etkinlik:
                                        <i class="bi bi-calendar-event text-info fs-5"></i>
                                        break;
                                    case DernekYonetim.Models.BildirimTuru.Duyuru:
                                        <i class="bi bi-megaphone text-primary fs-5"></i>
                                        break;
                                    case DernekYonetim.Models.BildirimTuru.Basvuru:
                                        <i class="bi bi-person-check text-success fs-5"></i>
                                        break;
                                    case DernekYonetim.Models.BildirimTuru.Sistem:
                                        <i class="bi bi-gear text-secondary fs-5"></i>
                                        break;
                                    default:
                                        <i class="bi bi-bell text-secondary fs-5"></i>
                                        break;
                                }
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start">
                                    <strong class="@(b.OkunduMu ? "text-muted fw-normal" : "")">@b.Baslik</strong>
                                    <small class="text-muted ms-3 flex-shrink-0">
                                        @b.OlusturmaTarihi.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                    </small>
                                </div>
                                <p class="mb-0 mt-1 @(b.OkunduMu ? "text-muted" : "") small">@b.Mesaj</p>
                                @if (!string.IsNullOrEmpty(b.YonlendirmeUrl))
                                {
                                    <a href="@b.YonlendirmeUrl" class="btn btn-link btn-sm px-0 mt-1">
                                        <i class="bi bi-arrow-right-circle"></i> Görüntüle
                                    </a>
                                }
                            </div>
                            @if (!b.OkunduMu)
                            {
                                <span class="badge bg-primary rounded-pill flex-shrink-0 mt-1">Yeni</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
