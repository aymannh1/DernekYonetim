@using Microsoft.AspNetCore.Identity
@inject UserManager<DernekYonetim.Models.Uye> LayoutUserManager
@inject DernekYonetim.Services.BildirimService LayoutBildirimService
@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
    var act  = ViewContext.RouteData.Values["action"]?.ToString();
    bool isAuth = User.Identity!.IsAuthenticated;

    string NavClass(string controller, string? action = null) {
        bool match = ctrl == controller && (action == null || act == action);
        return match ? "nav-item active" : "nav-item";
    }

    int okunmamisSayi = 0;
    if (isAuth)
    {
        var layoutUserId = LayoutUserManager.GetUserId(User);
        if (layoutUserId != null)
            okunmamisSayi = await LayoutBildirimService.OkunmamisSayiAsync(layoutUserId);
    }
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — HABSİS</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="@(isAuth ? "app-body" : "public-body")">

@if (isAuth)
{
    /* ── AUTHENTICATED: SIDEBAR LAYOUT ── */
    <aside class="app-sidebar" id="appSidebar">

        <div class="sidebar-brand">
            <a class="brand-link" asp-controller="Home" asp-action="Index">
                <div class="brand-icon"><i class="bi bi-globe2"></i></div>
                <div>
                    <span class="brand-name">HABSİS</span>
                    <span class="brand-sub">HAKİD Yönetim</span>
                </div>
            </a>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section">
                <span class="nav-section-label">GENEL</span>
                <ul class="nav-list">
                    <li>
                        <a class="@NavClass("Home")" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door"></i><span>Ana Sayfa</span>
                        </a>
                    </li>
                    <li>
                        <a class="@NavClass("Uye")" asp-controller="Uye" asp-action="Index">
                            <i class="bi bi-person-circle"></i><span>Üye Panelim</span>
                        </a>
                    </li>
                    <li>
                        <a class="@NavClass("Duyuru","Index")" asp-controller="Duyuru" asp-action="Index">
                            <i class="bi bi-megaphone"></i><span>Duyurular</span>
                        </a>
                    </li>
                    <li>
                        <a class="@NavClass("Etkinlik")" asp-controller="Etkinlik" asp-action="Index">
                            <i class="bi bi-calendar-event"></i><span>Etkinlikler</span>
                        </a>
                    </li>
                    <li>
                        <a class="@NavClass("Aidat","Aidatlarim")" asp-controller="Aidat" asp-action="Aidatlarim">
                            <i class="bi bi-cash-coin"></i><span>Aidatlarım</span>
                        </a>
                    </li>
                    <li>
                        <a class="@NavClass("Belge")" asp-controller="Belge" asp-action="Index">
                            <i class="bi bi-folder2-open"></i><span>Belgeler</span>
                        </a>
                    </li>
                    <li>
                        <a class="@NavClass("Proje")" asp-controller="Proje" asp-action="Index">
                            <i class="bi bi-globe-americas"></i><span>Projeler</span>
                        </a>
                    </li>
                    <li>
                        <a class="@NavClass("Bildirim") position-relative" asp-controller="Bildirim" asp-action="Index">
                            <i class="bi bi-bell"></i><span>Bildirimlerim</span>
                            @if (okunmamisSayi > 0)
                            {
                                <span class="badge bg-danger rounded-pill ms-auto">@(okunmamisSayi > 99 ? "99+" : okunmamisSayi.ToString())</span>
                            }
                        </a>
                    </li>
                </ul>
            </div>

            @if (User.IsInRole("Admin") || User.IsInRole("Yonetim"))
            {
                <div class="nav-section">
                    <span class="nav-section-label">YÖNETİM</span>
                    <ul class="nav-list">
                        <li>
                            <a class="@NavClass("Admin","Index")" asp-controller="Admin" asp-action="Index">
                                <i class="bi bi-speedometer2"></i><span>Yönetim Paneli</span>
                            </a>
                        </li>
                        <li>
                            <a class="@NavClass("Aidat","Index")" asp-controller="Aidat" asp-action="Index">
                                <i class="bi bi-cash-stack"></i><span>Aidat Yönetimi</span>
                            </a>
                        </li>
                        <li>
                            <a class="@NavClass("Duyuru","Yonetim")" asp-controller="Duyuru" asp-action="Yonetim">
                                <i class="bi bi-broadcast"></i><span>Duyuru Yönetimi</span>
                            </a>
                        </li>
                        <li>
                            <a class="@NavClass("Mali")" asp-controller="Mali" asp-action="Index">
                                <i class="bi bi-graph-up-arrow"></i><span>Mali İşlemler</span>
                            </a>
                        </li>
                        <li>
                            <a class="@NavClass("Admin","TopluMail")" asp-controller="Admin" asp-action="TopluMail">
                                <i class="bi bi-send"></i><span>Toplu Mesaj</span>
                            </a>
                        </li>
                    </ul>
                </div>
            }
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-user">
                <div class="user-avatar"><i class="bi bi-person-fill"></i></div>
                <div style="min-width:0">
                    <span class="user-name">@User.Identity.Name?.Split('@')[0]</span>
                    <span class="user-role">
                        @if (User.IsInRole("Admin")) { <text>Yönetici</text> }
                        else if (User.IsInRole("Yonetim")) { <text>Yönetim</text> }
                        else { <text>Üye</text> }
                    </span>
                </div>
            </div>
            <form asp-controller="Auth" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-logout" title="Çıkış Yap">
                    <i class="bi bi-box-arrow-right"></i>
                </button>
            </form>
        </div>
    </aside>

    <div class="app-main">
        <header class="app-header">
            <button class="sidebar-toggle" id="sidebarToggle">
                <i class="bi bi-list"></i>
            </button>
            <div class="header-title">
                <h1 class="page-title">@(ViewData["Title"] ?? "HABSİS")</h1>
            </div>
            <div class="header-actions">
                <a class="header-btn position-relative" asp-controller="Bildirim" asp-action="Index" title="Bildirimler">
                    <i class="bi bi-bell"></i>
                    @if (okunmamisSayi > 0)
                    {
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                              style="font-size:0.6rem">
                            @(okunmamisSayi > 99 ? "99+" : okunmamisSayi.ToString())
                        </span>
                    }
                </a>
                <a class="header-btn" asp-controller="Uye" asp-action="Index" title="Profilim">
                    <i class="bi bi-person-circle"></i>
                </a>
            </div>
        </header>

        <main class="app-content">
            @RenderBody()
        </main>

        <footer class="app-footer">
            <span>© @DateTime.Now.Year HABSİS</span>
            <span class="footer-sep">·</span>
            <span>Habesistan Kalkınma ve İşbirliği Derneği</span>
            <span class="footer-sep">·</span>
            <span>Tüm hakları saklıdır.</span>
        </footer>
    </div>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>
}
else
{
    /* ── PUBLIC: TOP NAV LAYOUT ── */
    <nav class="public-nav">
        <div class="container">
            <div class="nav-inner">
                <a class="pub-brand" asp-controller="Home" asp-action="Index">
                    <div class="pub-brand-icon"><i class="bi bi-globe2"></i></div>
                    <div>
                        <span class="pub-brand-name">HABSİS</span>
                        <span class="pub-brand-sub">HAKİD Yönetim Sistemi</span>
                    </div>
                </a>
                <div class="pub-nav-actions">
                    <a class="pub-nav-btn" asp-controller="Auth" asp-action="Login">
                        <i class="bi bi-person"></i> Giriş Yap
                    </a>
                    <a class="pub-nav-btn pub-nav-btn-primary" asp-controller="Auth" asp-action="Basvuru">
                        <i class="bi bi-person-plus"></i> Üye Ol
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <main class="public-content">
        @RenderBody()
    </main>

    <footer class="public-footer">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-7">
                    <div class="footer-brand-wrap">
                        <div class="footer-brand-icon"><i class="bi bi-globe2"></i></div>
                        <div>
                            <span class="footer-brand-name">HABSİS</span>
                            <span class="footer-brand-desc">Habesistan Kalkınma ve İşbirliği Derneği Yönetim Sistemi</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-5 text-md-end mt-3 mt-md-0">
                    <a class="footer-link" asp-controller="Auth" asp-action="Login">Giriş Yap</a>
                    <a class="footer-link ms-4" asp-controller="Auth" asp-action="Basvuru">Üye Ol</a>
                </div>
            </div>
            <hr class="footer-divider" />
            <div class="text-center small" style="color:#475569">
                © @DateTime.Now.Year HABSİS · Habesistan Kalkınma ve İşbirliği Derneği. Tüm hakları saklıdır.
            </div>
        </div>
    </footer>
}

<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Sidebar toggle
    const sidebar  = document.getElementById('appSidebar');
    const overlay  = document.getElementById('sidebarOverlay');
    const toggler  = document.getElementById('sidebarToggle');

    function openSidebar()  { sidebar?.classList.add('open');  overlay?.classList.add('show'); }
    function closeSidebar() { sidebar?.classList.remove('open'); overlay?.classList.remove('show'); }

    toggler?.addEventListener('click', () => {
        sidebar?.classList.contains('open') ? closeSidebar() : openSidebar();
    });
    overlay?.addEventListener('click', closeSidebar);
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
