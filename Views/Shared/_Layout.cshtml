
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Dernek Yönetim</title>

    <!-- Bootstrap 5 -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        body {
            background-color: #f8f9fa;
        }

        .navbar-brand {
            font-weight: 600;
        }

        footer {
            font-size: 0.85rem;
        }
    </style>
</head>
<body class="dernek-body">

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-building"></i> Dernek Yönetim
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav ms-auto">
                    @if (User.Identity!.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house"></i> Ana Sayfa
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Uye" asp-action="Index">
                                <i class="bi bi-person-circle"></i> Üye Panelim
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Duyuru" asp-action="Index">
                                <i class="bi bi-megaphone"></i> Duyurular
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Etkinlik" asp-action="Index">
                                <i class="bi bi-calendar-event"></i> Etkinlikler
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Aidat" asp-action="Aidatlarim">
                                <i class="bi bi-cash"></i> Aidatlarım
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Belge" asp-action="Index">
                                <i class="bi bi-folder2-open"></i> Belgeler
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Proje" asp-action="Index">
                                <i class="bi bi-globe2"></i> Projeler
                            </a>
                        </li>
                        @if (User.IsInRole("Admin") || User.IsInRole("Yonetim"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-speedometer2"></i> Yönetim Paneli
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Aidat" asp-action="Index">
                                    <i class="bi bi-cash-stack"></i> Aidat Yönetimi
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Duyuru" asp-action="Yonetim">
                                    <i class="bi bi-megaphone"></i> Duyuru Yönetimi
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Mali" asp-action="Index">
                                    <i class="bi bi-cash-stack"></i> Mali İşlemler
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="TopluMail">
                                    <i class="bi bi-envelope-paper"></i> Toplu Mail
                                </a>
                            </li>
                         
                        }
                        <li class="nav-item">
                            <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-link nav-link text-white">
                                    <i class="bi bi-box-arrow-right"></i> Çıkış
                                </button>
                            </form>
                        </li>
                   

                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Auth" asp-action="Login">
                                <i class="bi bi-person"></i> Giriş Yap
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Auth" asp-action="Basvuru">
                                <i class="bi bi-person-plus"></i> Üye Ol
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- İÇERİK -->
    <main class="py-4">
        @RenderBody()
    </main>
    <!-- FOOTER -->
    <footer class="bg-dark text-white py-4 mt-4">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h6 class="fw-bold">
                        <i class="bi bi-building"></i> Dernek Yönetim Sistemi
                    </h6>
                    <p class="text-muted small mb-0">
                        Üye işlemleri, aidat takibi ve etkinlik yönetimi.
                    </p>
                </div>

                <div class="col-md-6 text-md-end">
                    <a asp-controller="Auth" asp-action="Login"
                       class="text-white text-decoration-none small me-3">
                        <i class="bi bi-person"></i> Giriş Yap
                    </a>

                    <a asp-controller="Auth" asp-action="Basvuru"
                       class="text-white text-decoration-none small">
                        <i class="bi bi-person-plus"></i> Üye Ol
                    </a>
                </div>
            </div>

            <hr class="border-secondary mt-3 mb-2" />

            <div class="text-center text-muted small">
                © @DateTime.Now.Year Dernek Yönetim Sistemi. Tüm hakları saklıdır.
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>