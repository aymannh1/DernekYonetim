@{
    ViewData["Title"] = "Başvuru Alındı";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="success-wrap">
    <div class="success-card card">
        <div class="card-body" style="padding:44px 32px">

            <div class="success-icon-wrap">
                <i class="bi bi-check-lg"></i>
            </div>

            <h4 class="fw-700 mb-2" style="color:var(--text-dark)">Başvurunuz Alındı!</h4>
            <p class="text-muted mb-4" style="font-size:14px;line-height:1.65">
                Üyelik başvurunuz başarıyla gönderildi. Yöneticimiz tarafından
                incelendikten sonra e-posta ile bilgilendirileceksiniz.
            </p>

            <div class="alert alert-info mb-4" style="text-align:left">
                <i class="bi bi-info-circle"></i>
                <span>Başvurunuzun değerlendirilmesi genellikle <strong>1–3 iş günü</strong> sürmektedir.</span>
            </div>

            <a asp-action="Login" class="btn btn-primary btn-lg w-100">
                <i class="bi bi-box-arrow-in-right"></i> Giriş Sayfasına Dön
            </a>

            <a asp-controller="Home" asp-action="Index"
               class="btn btn-outline-secondary w-100 mt-2" style="font-size:13.5px">
                <i class="bi bi-house"></i> Ana Sayfaya Git
            </a>

        </div>
    </div>
</div>
