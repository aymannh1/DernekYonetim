@model DernekYonetim.ViewModels.TopluMailViewModel
@{
    ViewData["Title"] = "Toplu Mesaj Gönder";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4><i class="bi bi-send"></i> Toplu Mesaj Gönder</h4>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left"></i> Panele Dön
                </a>
            </div>

            @if (TempData["Basari"] != null)
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle"></i> @TempData["Basari"]
                </div>
            }
            @if (TempData["Hata"] != null)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-x-circle"></i> @TempData["Hata"]
                </div>
            }

            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="TopluMail" method="post"
                          onsubmit="return confirm('Toplu mesaj göndermek istediğinizden emin misiniz?')">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                        <!-- HEDEF -->
                        <div class="mb-3">
                            <label class="form-label">Alıcı Grubu *</label>
                            <div class="d-flex gap-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio"
                                           name="Hedef" value="Tumu" id="h1" checked />
                                    <label class="form-check-label" for="h1">
                                        <i class="bi bi-people"></i> Tüm Üyeler
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio"
                                           name="Hedef" value="Aktif" id="h2" />
                                    <label class="form-check-label" for="h2">
                                        <i class="bi bi-person-check"></i> Sadece Aktif Üyeler
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio"
                                           name="Hedef" value="Gecikti" id="h3" />
                                    <label class="form-check-label" for="h3">
                                        <i class="bi bi-exclamation-triangle text-danger"></i> Aidatı Gecikenler
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- KONU -->
                        <div class="mb-3">
                            <label asp-for="Konu" class="form-label">Başlık *</label>
                            <input asp-for="Konu" class="form-control"
                                   placeholder="Mesaj başlığı" />
                            <span asp-validation-for="Konu" class="text-danger small"></span>
                        </div>

                        <!-- İÇERİK -->
                        <div class="mb-3">
                            <label asp-for="Icerik" class="form-label">Mesaj *</label>
                            <textarea asp-for="Icerik" class="form-control" rows="8"
                                      placeholder="Mesaj içeriğini buraya yazın..."></textarea>
                            <span asp-validation-for="Icerik" class="text-danger small"></span>
                        </div>

                        <div class="alert alert-info small">
                            <i class="bi bi-info-circle"></i>
                            Mesaj, seçilen gruptaki tüm üyelerin bildirim kutusuna iletilecektir.
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-send"></i> Gönder
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}