@model DernekYonetim.Models.Uye
@{
    ViewData["Title"] = "Üye Detay";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4><i class="bi bi-person-badge"></i> Üye Detay</h4>
        <a asp-action="Uyeler" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Listeye Dön
        </a>
    </div>

    @if (TempData["Basari"] != null)
    {
        <div class="alert alert-success">@TempData["Basari"]</div>
    }

    <div class="row g-4">
        <!-- BİLGİLER -->
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header"><strong>Üye Bilgileri</strong></div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Üye No</dt>
                        <dd class="col-sm-8"><span class="badge bg-secondary">@Model.UyeNo</span></dd>

                        <dt class="col-sm-4">Ad Soyad</dt>
                        <dd class="col-sm-8">@Model.TamAd</dd>

                        <dt class="col-sm-4">E-posta</dt>
                        <dd class="col-sm-8">@Model.Email</dd>

                        <dt class="col-sm-4">Telefon</dt>
                        <dd class="col-sm-8">@Model.Telefon</dd>

                        <dt class="col-sm-4">Meslek</dt>
                        <dd class="col-sm-8">@(Model.Meslek ?? "-")</dd>

                        <dt class="col-sm-4">Adres</dt>
                        <dd class="col-sm-8">@(Model.Adres ?? "-")</dd>

                        <dt class="col-sm-4">Kayıt Tarihi</dt>
                        <dd class="col-sm-8">@Model.UyelikTarihi.ToString("dd.MM.yyyy")</dd>

                        <dt class="col-sm-4">Son Giriş</dt>
                        <dd class="col-sm-8">@(Model.SonGiris?.ToString("dd.MM.yyyy HH:mm") ?? "-")</dd>
                    </dl>
                </div>
            </div>
        </div>

        <!-- DURUM GÜNCELLE -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header"><strong>Durum Güncelle</strong></div>
                <div class="card-body">
                    <form asp-action="DurumGuncelle" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="mb-3">
                            <select name="durum" class="form-select">
                                @foreach (var d in Enum.GetValues<DernekYonetim.Models.UyelikDurumu>())
                                {
                                    <option value="@d" selected="@(Model.UyelikDurumu == d)">@d</option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Güncelle</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>