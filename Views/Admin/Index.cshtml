@model DernekYonetim.Services.UyeIstatistik
@{
    ViewData["Title"] = "Yönetim Paneli";
}

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card">
            <div class="card-body">
                <div class="stat-icon si-blue"><i class="bi bi-people"></i></div>
                <div class="stat-content">
                    <span class="stat-label">Toplam Üye</span>
                    <span class="stat-value">@Model.Toplam</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card">
            <div class="card-body">
                <div class="stat-icon si-green"><i class="bi bi-person-check"></i></div>
                <div class="stat-content">
                    <span class="stat-label">Aktif Üye</span>
                    <span class="stat-value">@Model.Aktif</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card">
            <div class="card-body">
                <div class="stat-icon si-amber"><i class="bi bi-person-plus"></i></div>
                <div class="stat-content">
                    <span class="stat-label">Bu Ay Yeni</span>
                    <span class="stat-value">@Model.BuAyYeni</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card">
            <div class="card-body">
                <div class="stat-icon si-red"><i class="bi bi-hourglass-split"></i></div>
                <div class="stat-content">
                    <span class="stat-label">Bekleyen Başvuru</span>
                    <span class="stat-value">@Model.BekleyenBasvuru</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-3">
    <div class="col-md-4">
        <a asp-action="Uyeler" class="text-decoration-none">
            <div class="card quick-card">
                <div class="card-body">
                    <div class="quick-icon" style="background:var(--primary-light);color:var(--primary)">
                        <i class="bi bi-person-lines-fill"></i>
                    </div>
                    <h6 class="fw-600 mb-1" style="color:var(--text-dark)">Üye Yönetimi</h6>
                    <p class="text-muted mb-3" style="font-size:13px">Üyeleri listele ve durum güncelle</p>
                    <span class="btn btn-outline-primary btn-sm">Üyelere Git</span>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-action="Basvurular" class="text-decoration-none">
            <div class="card quick-card">
                <div class="card-body">
                    <div class="quick-icon" style="background:var(--gold-light);color:var(--gold)">
                        <i class="bi bi-clipboard-check"></i>
                    </div>
                    <h6 class="fw-600 mb-1" style="color:var(--text-dark)">Başvurular</h6>
                    <p class="text-muted mb-3" style="font-size:13px">Bekleyen başvuruları incele ve onayla</p>
                    <span class="btn btn-sm" style="background:var(--gold-light);color:var(--gold);border:1px solid var(--gold)">
                        Başvurulara Git
                    </span>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Mali" asp-action="Index" class="text-decoration-none">
            <div class="card quick-card">
                <div class="card-body">
                    <div class="quick-icon" style="background:var(--success-light);color:var(--success)">
                        <i class="bi bi-graph-up-arrow"></i>
                    </div>
                    <h6 class="fw-600 mb-1" style="color:var(--text-dark)">Mali İşlemler</h6>
                    <p class="text-muted mb-3" style="font-size:13px">Gelir, gider ve mali raporlar</p>
                    <span class="btn btn-outline-success btn-sm">Mali Panele Git</span>
                </div>
            </div>
        </a>
    </div>
</div>
