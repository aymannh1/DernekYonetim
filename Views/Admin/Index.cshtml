@model DernekYonetim.Services.UyeIstatistik
@{
    ViewData["Title"] = "Admin Paneli";
}

<div class="container">
    <h4 class="mb-4"><i class="bi bi-speedometer2"></i> Admin Paneli</h4>

    <!-- İSTATİSTİK KARTLARI -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small">Toplam Üye</div>
                            <div class="fs-2 fw-bold">@Model.Toplam</div>
                        </div>
                        <i class="bi bi-people fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small">Aktif Üye</div>
                            <div class="fs-2 fw-bold">@Model.Aktif</div>
                        </div>
                        <i class="bi bi-person-check fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small">Bu Ay Yeni</div>
                            <div class="fs-2 fw-bold">@Model.BuAyYeni</div>
                        </div>
                        <i class="bi bi-person-plus fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small">Bekleyen Başvuru</div>
                            <div class="fs-2 fw-bold">@Model.BekleyenBasvuru</div>
                        </div>
                        <i class="bi bi-hourglass-split fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- HIZLI ERİŞİM -->
    <div class="row g-3">
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <i class="bi bi-person-lines-fill fs-1 text-primary mb-3 d-block"></i>
                    <h6>Üye Yönetimi</h6>
                    <p class="text-muted small">Üyeleri listele, durum güncelle</p>
                    <a asp-action="Uyeler" class="btn btn-outline-primary btn-sm">Üyelere Git</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <i class="bi bi-clipboard-check fs-1 text-warning mb-3 d-block"></i>
                    <h6>Başvurular</h6>
                    <p class="text-muted small">Bekleyen başvuruları incele</p>
                    <a asp-action="Basvurular" class="btn btn-outline-warning btn-sm">Başvurulara Git</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <i class="bi bi-cash-stack fs-1 text-success mb-3 d-block"></i>
                    <h6>Mali İşlemler</h6>
                    <p class="text-muted small">Gelir/gider takibi</p>
                    <a href="#" class="btn btn-outline-success btn-sm">Yakında</a>
                </div>
            </div>
        </div>
    </div>
</div>